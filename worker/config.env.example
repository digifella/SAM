# Queue server endpoint on your website
QUEUE_SERVER_URL=https://longboardfella.com.au/admin/queue_worker_api.php

# Must match QUEUE_SECRET_KEY in site/comments/config.php
QUEUE_SECRET_KEY=replace_me

# Worker identity shown in queue job metadata
WORKER_ID=sam-audio-worker-1

# Comma-separated queue job types this worker can claim
SUPPORTED_TYPES=sam_audio_cleanup

# Polling / reliability
POLL_INTERVAL=15
HEARTBEAT_INTERVAL=60
REQUEST_TIMEOUT=120
LOG_LEVEL=INFO

# Temporary processing workspace
TEMP_DIR=./worker/tmp

# SAM-Audio runtime defaults (can be overridden per job in input_data)
SAM_MODEL_DIR=/home/longboardfella/models/sam-audio-large-tv
FFMPEG_BIN=ffmpeg
